class Solution {
    public int[] sortByBits(int[] arr) {
        for(int i=0;i<arr.length;i++){
            int originalV=arr[i];
            int binary=Integer.bitCount(originalV);
            arr[i]=originalV+(binary*100000);
        }
        Arrays.sort(arr);

        for(int i=0;i<arr.length;i++){
            int val=arr[i]%100000;
            arr[i]=val;
        }
        return arr;
    }
    
}
